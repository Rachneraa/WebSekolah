            <!-- COPYRIGHT FOOTER MATCHING MOCKUP -->
            <div class="pt-8 text-center text-xs text-slate-500">
                <p>© 2026 SMP Negeri 16 Cimahi. Terakreditasi A (Unggul)</p>
            </div>
