    <!-- MODAL PPDB -->
    <div id="ppdb-modal" class="fixed inset-0 z-50 hidden bg-slate-950/70 backdrop-blur-sm flex items-center justify-center p-4 overflow-y-auto">
        <div class="bg-white rounded-2xl max-w-lg w-full p-6 sm:p-8 shadow-2xl relative border border-slate-100 my-8">
            <button onclick="closePpdbModal()" class="absolute top-4 right-4 text-slate-400 hover:text-slate-700 w-8 h-8 rounded-full bg-slate-100 flex items-center justify-center">
                <i class="fa-solid fa-xmark text-base"></i>
            </button>
            
            <div class="space-y-2 mb-6">
                <span class="px-2.5 py-1 bg-brand-softBlue text-brand-blue text-xs font-bold rounded">Pendaftaran</span>
                <h3 class="text-2xl font-extrabold text-slate-900">Gabung Ekstrakulikuler</h3>
                <p class="text-slate-500 text-xs sm:text-sm">Daftarkan diri Anda untuk mengikuti kegiatan ekstrakulikuler SMPN 16 Cimahi.</p>
            </div>

            <form onsubmit="submitPpdbForm(event)" class="space-y-4">
                <div>
                    <label class="block text-xs font-bold text-slate-700 uppercase mb-1">Nama Lengkap Siswa</label>
                    <input type="text" required placeholder="Contoh: Muhammad Rizky" class="w-full px-4 py-2.5 rounded-lg border border-slate-300 text-sm focus:ring-2 focus:ring-brand-blue focus:outline-none">
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-xs font-bold text-slate-700 uppercase mb-1">Kelas</label>
                        <input type="text" required placeholder="Contoh: VII-A" class="w-full px-4 py-2.5 rounded-lg border border-slate-300 text-sm focus:ring-2 focus:ring-brand-blue focus:outline-none">
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-slate-700 uppercase mb-1">No. WhatsApp</label>
                        <input type="tel" required placeholder="0812xxxx" class="w-full px-4 py-2.5 rounded-lg border border-slate-300 text-sm focus:ring-2 focus:ring-brand-blue focus:outline-none">
                    </div>
                </div>

                <button type="submit" class="w-full py-3 bg-brand-navy hover:bg-brand-blue text-white font-bold rounded-xl shadow transition-colors">
                    Kirim Pendaftaran
                </button>
            </form>
        </div>
    </div>

    <!-- MODAL KONTAK -->
    <div id="contact-modal" class="fixed inset-0 z-50 hidden bg-slate-950/70 backdrop-blur-sm flex items-center justify-center p-4 overflow-y-auto">
        <div class="bg-white rounded-2xl max-w-lg w-full p-6 sm:p-8 shadow-2xl relative border border-slate-100 my-8">
            <button onclick="closeContactModal()" class="absolute top-4 right-4 text-slate-400 hover:text-slate-700 w-8 h-8 rounded-full bg-slate-100 flex items-center justify-center">
                <i class="fa-solid fa-xmark text-base"></i>
            </button>
            
            <div class="space-y-2 mb-6">
                <h3 class="text-2xl font-extrabold text-slate-900">Hubungi Pembina Ekstrakulikuler</h3>
                <p class="text-slate-500 text-xs sm:text-sm">Kirim pesan langsung ke koordinator kesiswaan dan pembina.</p>
            </div>

            <form onsubmit="submitContactForm(event)" class="space-y-4">
                <div>
                    <label class="block text-xs font-bold text-slate-700 uppercase mb-1">Nama Lengkap</label>
                    <input type="text" required placeholder="Nama Anda" class="w-full px-4 py-2.5 rounded-lg border border-slate-300 text-sm focus:ring-2 focus:ring-brand-blue focus:outline-none">
                </div>

                <div>
                    <label class="block text-xs font-bold text-slate-700 uppercase mb-1">Pesan / Pertanyaan</label>
                    <textarea required rows="3" placeholder="Tuliskan pertanyaan Anda..." class="w-full px-4 py-2.5 rounded-lg border border-slate-300 text-sm focus:ring-2 focus:ring-brand-blue focus:outline-none"></textarea>
                </div>

                <button type="submit" class="w-full py-3 bg-brand-navy hover:bg-brand-blue text-white font-bold rounded-xl shadow transition-colors">
                    Kirim Pesan
                </button>
            </form>
        </div>
    </div>

    <!-- MODAL PHOTO LIGHTBOX -->
    <div id="photo-modal" class="fixed inset-0 z-50 hidden bg-slate-950/90 backdrop-blur-md flex items-center justify-center p-4" onclick="closePhotoModal()">
        <div class="max-w-4xl w-full relative">
            <img id="photo-modal-img" src="" class="w-full max-h-[85vh] object-contain rounded-xl shadow-2xl" alt="Foto Galeri">
            <p class="text-center text-white text-xs mt-3 font-medium">Klik di mana saja untuk menutup</p>
        </div>
    </div>

    <!-- JAVASCRIPT -->
    <script>
        const dataEkskul = {
            paskibra: {
                title: "Ekstrakulikuler Paskibra",
                badge: "Kepemimpinan & Kedisiplinan",
                desc: "Wadah pengembangan bakat, minat, dan potensi siswa di luar jam pelajaran kurikuler. Bergabunglah dan temukan passion Anda bersama kami.",
                heroImg: "https://images.unsplash.com/photo-1526976668912-1a811878dd37?auto=format&fit=crop&w=800&q=80",
                instructorName: "Susan S.T",
                instructorRole: "Pembina Ekstrakulikuler Paskibra",
                instructorSchedule: "Jadwal Latihan: Setiap Selasa & Kamis (15:00 - 17:00 WIB)",
                instructorImg: "https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?auto=format&fit=crop&w=600&q=80",
                prestasi: [
                    { title: "Juara Umum Paskibra", desc: "Tingkat Provinsi Jawa Barat 2023" },
                    { title: "Medali Emas Math Club", desc: "Olimpiade Sains Nasional 2023" },
                    { title: "Grup Teater Terbaik", desc: "Festival Seni Pelajar Kota Cimahi" }
                ]
            },
            pramuka: {
                title: "Ekstrakulikuler Pramuka",
                badge: "Kepramukaan & Alam",
                desc: "Membentuk karakter pemuda yang tangguh, mandiri, peduli sesama, dan mencintai kelestarian alam nusantara.",
                heroImg: "https://images.unsplash.com/photo-1478131143081-80f7f84ca84d?auto=format&fit=crop&w=800&q=80",
                instructorName: "Dra. Siti Rahma",
                instructorRole: "Pembina Gudep Pramuka",
                instructorSchedule: "Jadwal Latihan: Setiap Jumat (14:00 - 16:30 WIB)",
                instructorImg: "https://images.unsplash.com/photo-1580894732468-9111ad068560?auto=format&fit=crop&w=600&q=80",
                prestasi: [
                    { title: "Juara 1 Jambore Kebangsaan", desc: "Tingkat Kota Cimahi 2023" },
                    { title: "Regu Terbaik PBB & Pionering", desc: "Lomba Pramuka Penegak 2023" },
                    { title: "Penghargaan Lingkungan Hidup", desc: "Pramuka Peduli Jabar 2023" }
                ]
            },
            english: {
                title: "English Club",
                badge: "Seni & Bahasa Internasional",
                desc: "Meningkatkan kepercayaan diri siswa dalam berbahasa Inggris melalui debat, pidato, drama, dan storytelling interaktif.",
                heroImg: "https://images.unsplash.com/photo-1523240795612-9a054b0db644?auto=format&fit=crop&w=800&q=80",
                instructorName: "Maya Indriani, M.Pd",
                instructorRole: "Pembina English Club",
                instructorSchedule: "Jadwal Latihan: Setiap Rabu (15:30 - 17:00 WIB)",
                instructorImg: "https://images.unsplash.com/photo-1544005313-94ddf0286df2?auto=format&fit=crop&w=600&q=80",
                prestasi: [
                    { title: "Juara 1 English Speech Contest", desc: "Tingkat Kota Cimahi 2023" },
                    { title: "Runner-Up Storytelling", desc: "Festival Bahasa Jawa Barat 2023" },
                    { title: "Best Debater Student", desc: "Inter-School Debate 2023" }
                ]
            },
            pmr: {
                title: "Palang Merah Remaja (PMR)",
                badge: "Kesehatan & Kemanusiaan",
                desc: "Memberikan pengetahuan pertolongan pertama, kesehatan remaja, dan jiwa kepedulian sosial bagi sesama.",
                heroImg: "https://images.unsplash.com/photo-1584515979956-d9f6e5d09982?auto=format&fit=crop&w=800&q=80",
                instructorName: "drh. Anita Widyastuti",
                instructorRole: "Pembina Unit PMR Wira",
                instructorSchedule: "Jadwal Latihan: Setiap Sabtu (09:00 - 11:30 WIB)",
                instructorImg: "https://images.unsplash.com/photo-1559839734-2b71ea197ec2?auto=format&fit=crop&w=600&q=80",
                prestasi: [
                    { title: "Juara Umum Lomba Pertolongan Pertama", desc: "PMI Jawa Barat 2023" },
                    { title: "Penghargaan Donor Darah Remaja", desc: "PMI Kota Cimahi 2023" },
                    { title: "PMR Madya Terbaik", desc: "Jumpa Bakti Gembira 2023" }
                ]
            },
            basket: {
                title: "Bola Basket & Voli",
                badge: "Olahraga & Kebugaran",
                desc: "Melatih stamina, ketangkasan, dan kerjasama tim melalui kompetisi olahraga antar sekolah tingkat daerah.",
                heroImg: "https://images.unsplash.com/photo-1546519638-68e109498ffc?auto=format&fit=crop&w=800&q=80",
                instructorName: "Ahmad Hidayat, S.Pd",
                instructorRole: "Pelatih Utama Olahraga",
                instructorSchedule: "Jadwal Latihan: Setiap Senin & Kamis (15:30 - 17:30 WIB)",
                instructorImg: "https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?auto=format&fit=crop&w=600&q=80",
                prestasi: [
                    { title: "Juara 1 Basket SMP Cup", desc: "Tingkat Kota Cimahi 2023" },
                    { title: "Medali Perak Voli Putra", desc: "O2SN SMP 2023" },
                    { title: "Pemain Terbaik (MVP)", desc: "Turnamen Pelajar Cimahi 2023" }
                ]
            },
            musik: {
                title: "Seni Musik & Band",
                badge: "Kreativitas & Seni Suara",
                desc: "Mengembangkan bakat seni instrumen musik, vokal, dan grup musik pelajar untuk ajang pertunjukan dan perlombaan.",
                heroImg: "https://images.unsplash.com/photo-1511671782779-c97d3d27a1d4?auto=format&fit=crop&w=800&q=80",
                instructorName: "Rian Febrian, S.Sn",
                instructorRole: "Pembina Seni Musik",
                instructorSchedule: "Jadwal Latihan: Setiap Rabu & Sabtu (14:00 - 16:30 WIB)",
                instructorImg: "https://images.unsplash.com/photo-1500648767791-00dcc994a43e?auto=format&fit=crop&w=600&q=80",
                prestasi: [
                    { title: "Juara 1 FLS2N Gitar Duet", desc: "Tingkat Kota Cimahi 2023" },
                    { title: "Grup Band Pelajar Terbaik", desc: "Pentas Seni Budaya 2023" },
                    { title: "Penyanyi Solo Terbaik", desc: "Lomba Vokal SMP 2023" }
                ]
            }
        };

        function switchEkskul(key) {
            const item = dataEkskul[key];
            if (!item) return;

            // Update UI elements
            document.getElementById('ekskul-title').innerText = item.title;
            document.getElementById('ekskul-badge').innerText = item.badge;
            document.getElementById('ekskul-desc').innerText = item.desc;
            document.getElementById('ekskul-hero-img').src = item.heroImg;

            document.getElementById('instructor-name').innerText = item.instructorName;
            document.getElementById('instructor-role').innerText = item.instructorRole;
            document.getElementById('instructor-schedule').innerText = item.instructorSchedule;
            document.getElementById('instructor-img').src = item.instructorImg;

            document.getElementById('prestasi-title-1').innerText = item.prestasi[0].title;
            document.getElementById('prestasi-desc-1').innerText = item.prestasi[0].desc;
            document.getElementById('prestasi-title-2').innerText = item.prestasi[1].title;
            document.getElementById('prestasi-desc-2').innerText = item.prestasi[1].desc;
            document.getElementById('prestasi-title-3').innerText = item.prestasi[2].title;
            document.getElementById('prestasi-desc-3').innerText = item.prestasi[2].desc;

            // Update tabs styling
            document.querySelectorAll('.ekskul-selector-btn').forEach(btn => {
                btn.className = 'ekskul-selector-btn px-4 py-1.5 rounded-full bg-white border border-slate-300 text-slate-700 font-semibold hover:bg-slate-100 transition-colors shrink-0';
            });
            const activeBtn = document.getElementById('tab-' + key);
            if (activeBtn) {
                activeBtn.className = 'ekskul-selector-btn px-4 py-1.5 rounded-full bg-brand-navy text-white font-semibold transition-colors shrink-0';
            }
        }

        // READ URL PARAMETER IF ANY
        window.addEventListener('DOMContentLoaded', () => {
            const urlParams = new URLSearchParams(window.location.search);
            const type = urlParams.get('type') || 'paskibra';
            if (dataEkskul[type]) {
                switchEkskul(type);
            }
        });

        // MOBILE MENU
        function toggleMobileMenu() {
            const menu = document.getElementById('mobile-menu');
            const icon = document.getElementById('menu-icon');
            menu.classList.toggle('hidden');
            if (menu.classList.contains('hidden')) {
                icon.className = 'fa-solid fa-bars text-2xl';
            } else {
                icon.className = 'fa-solid fa-xmark text-2xl';
            }
        }

        // MODAL FUNCTIONS
        function openPpdbModal(e) {
            if (e) e.preventDefault();
            document.getElementById('ppdb-modal').classList.remove('hidden');
        }
        function closePpdbModal() {
            document.getElementById('ppdb-modal').classList.add('hidden');
        }
        function submitPpdbForm(e) {
            e.preventDefault();
            alert('Pendaftaran berhasil dikirim! Pembina akan menghubungi Anda melalui WhatsApp.');
            closePpdbModal();
            e.target.reset();
        }

        function openContactModal() {
            document.getElementById('contact-modal').classList.remove('hidden');
        }
        function closeContactModal() {
            document.getElementById('contact-modal').classList.add('hidden');
        }
        function submitContactForm(e) {
            e.preventDefault();
            alert('Pesan berhasil terkirim. Terima kasih telah menghubungi pembina.');
            closeContactModal();
            e.target.reset();
        }

        function openPhotoModal(container) {
            const img = container.querySelector('img');
            if (img) {
                document.getElementById('photo-modal-img').src = img.src;
                document.getElementById('photo-modal').classList.remove('hidden');
            }
        }
        function closePhotoModal() {
            document.getElementById('photo-modal').classList.add('hidden');
        }
    </script>
</body>
</html>
