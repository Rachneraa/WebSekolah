    </main>

    <!-- FOOTER SECTION MATCHING MOCKUP IMAGE & MAIN PAGE -->
    <footer class="bg-brand-dark text-slate-300 pt-16 pb-12 border-t border-slate-800">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="grid grid-cols-1 md:grid-cols-12 gap-10 pb-12 border-b border-slate-800">
                
                <!-- BRAND INFO -->
                <div class="md:col-span-5 space-y-4">
                    <div class="flex items-center gap-3">
                        <div class="w-10 h-10 rounded-lg bg-white/10 flex items-center justify-center text-white font-bold">
                            <i class="fa-solid fa-school text-lg"></i>
                        </div>
                        <span class="font-extrabold text-xl text-white tracking-tight">SMPN 16 Cimahi</span>
                    </div>
                    <p class="text-xs sm:text-sm text-slate-400 leading-relaxed max-w-sm">
                        Membentuk generasi cerdas, berkarakter, dan berwawasan global melalui pendidikan berkualitas.
                    </p>
                </div>

                <!-- TAUTAN PANTAS -->
                <div class="md:col-span-3 space-y-3">
                    <p class="text-xs font-bold text-white uppercase tracking-wider">Tautan Pantas</p>
                    <ul class="space-y-2 text-xs sm:text-sm text-slate-400">
                        <li><a href="index.html#tentang" class="hover:text-white transition-colors">Kurikulum</a></li>
                        <li><a href="index.html#berita" class="hover:text-white transition-colors">Kalender Akademik</a></li>
                        <li><a href="index.html" class="hover:text-white transition-colors">Perpustakaan Digital</a></li>
                    </ul>
                </div>

                <!-- PORTAL -->
                <div class="md:col-span-4 space-y-3">
                    <p class="text-xs font-bold text-white uppercase tracking-wider">Portal</p>
                    <ul class="space-y-2 text-xs sm:text-sm text-slate-400">
                        <li><a href="index.html#ppdb" onclick="openPpdbModal(event)" class="hover:text-white transition-colors">E-Learning</a></li>
                        <li><a href="#" class="hover:text-white transition-colors">Alumni</a></li>
                        <li><a href="#" class="hover:text-white transition-colors">Peta Situs</a></li>
